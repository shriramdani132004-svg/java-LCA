    <servlet>
        <servlet-name>AddCompanyServlet</servlet-name>
        <servlet-class>com.project.servlet.AddCompanyServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AddCompanyServlet</servlet-name>
        <url-pattern>/addCompany</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AddInternshipServlet</servlet-name>
