        <servlet-class>com.project.servlet.LogActivityServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogActivityServlet</servlet-name>
        <url-pattern>/logActivity</url-pattern>
    </servlet-mapping>

