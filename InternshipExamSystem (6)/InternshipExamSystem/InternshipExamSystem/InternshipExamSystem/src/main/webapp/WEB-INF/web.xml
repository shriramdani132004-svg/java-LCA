    <servlet>
        <servlet-name>ViewApplicationsServlet</servlet-name>
        <servlet-class>com.project.servlet.ViewApplicationsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ViewApplicationsServlet</servlet-name>
        <url-pattern>/viewApplications</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>UpdateApplicationStatusServlet</servlet-name>
        <servlet-class>com.project.servlet.UpdateApplicationStatusServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>UpdateApplicationStatusServlet</servlet-name>
        <url-pattern>/updateStatus</url-pattern>
    </servlet-mapping>

    <!-- ================= EXAM ================= -->
    <servlet>
        <servlet-name>StartExamServlet</servlet-name>
        <servlet-class>com.project.servlet.StartExamServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>StartExamServlet</servlet-name>
        <url-pattern>/startExam</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ViewExamServlet</servlet-name>
        <servlet-class>com.project.servlet.ViewExamServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ViewExamServlet</servlet-name>
        <url-pattern>/viewExam</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>SubmitExamServlet</servlet-name>
        <servlet-class>com.project.servlet.SubmitExamServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SubmitExamServlet</servlet-name>
        <url-pattern>/submitExam</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ViewResultsServlet</servlet-name>
        <servlet-class>com.project.servlet.ViewResultsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ViewResultsServlet</servlet-name>
        <url-pattern>/viewResults</url-pattern>
    </servlet-mapping>

    <!-- ================= ADMIN LOGS ================= -->
    <servlet>
        <servlet-name>ViewLogsServlet</servlet-name>
        <servlet-class>com.project.servlet.ViewLogsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ViewLogsServlet</servlet-name>
        <url-pattern>/viewLogs</url-pattern>
    </servlet-mapping>

    <servlet>
